# Polymarket Trading Bot Environment Variables
# Copy this file to .env and fill in your values
# Load with: source .env or use python-dotenv

# =============================================================================
# Required: Wallet Configuration
# =============================================================================

# Your MetaMask private key (64 hex characters, with or without 0x prefix)
# WARNING: Never commit this to git!
POLY_PRIVATE_KEY=

# Your Polymarket Safe/Proxy wallet address
# Find at: polymarket.com/settings -> General -> Wallet Address
POLY_SAFE_ADDRESS=

# =============================================================================
# Required for Gasless Trading: Builder Program Credentials
# =============================================================================

# Apply for Builder Program at: polymarket.com/settings?tab=builder
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=
# Your builder bytes32 code — find it at polymarket.com/settings → Codici builder
POLY_BUILDER_CODE=

# =============================================================================
# Optional: Network Configuration
# =============================================================================

# Polygon RPC URL (default: https://polygon-rpc.com)
# POLY_RPC_URL=https://polygon-rpc.com

# Chain ID (default: 137 for Polygon mainnet)
# POLY_CHAIN_ID=137

# CLOB API host (default: https://clob.polymarket.com)
# POLY_CLOB_HOST=https://clob.polymarket.com

# =============================================================================
# Trading Mode & Defaults
# =============================================================================

# Paper trading mode (true = no real money, false = live trading)
# Default is true (safe). Change to false only when ready to go live.
PAPER_MODE=true

# USDC amount per trade (used by run_paper.py if --size not specified)
TRADE_SIZE=1.0

# =============================================================================
# Optional: Paths and Logging
# =============================================================================

# Directory for storing encrypted credentials
# POLY_DATA_DIR=credentials

# Logging level: DEBUG, INFO, WARNING, ERROR
# POLY_LOG_LEVEL=INFO
